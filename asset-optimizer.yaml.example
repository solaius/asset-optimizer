# Asset Optimizer Configuration
# Copy to asset-optimizer.yaml and customize.
# Supports ${ENV_VAR} interpolation for secrets.
# Environment variables in .env override values here.

storage:
  backend: sqlite                    # sqlite | postgres
  sqlite_path: ./data/optimizer.db
  # postgres_url: ${DATABASE_URL}

providers:
  text:
    default: ${AO_DEFAULT_TEXT_PROVIDER}
    claude:
      api_key: ${ANTHROPIC_API_KEY}
      model: claude-sonnet-4-20250514
    openai:
      api_key: ${OPENAI_API_KEY}
      model: gpt-4o
    gemini:
      api_key: ${GEMINI_API_KEY}
      model: gemini-2.0-flash
    # vllm:
    #   base_url: ${VLLM_BASE_URL}
    #   model: ${VLLM_MODEL}
    #   api_key: ${VLLM_API_KEY}
    # ollama:
    #   base_url: ${OLLAMA_BASE_URL}
    #   model: ${OLLAMA_MODEL}
  image:
    default: ${AO_DEFAULT_IMAGE_PROVIDER}
    openai_image:
      api_key: ${OPENAI_API_KEY}
      model: dall-e-3
    nano_banana:
      api_key: ${NANO_BANANA_API_KEY}
      endpoint: ${NANO_BANANA_ENDPOINT}
  judge:
    provider: ${AO_JUDGE_PROVIDER}   # blank = same as text default
    model: ${AO_JUDGE_MODEL}

server:
  host: 0.0.0.0
  port: 8000

defaults:
  max_iterations: ${AO_MAX_ITERATIONS}
  min_improvement: ${AO_MIN_IMPROVEMENT}
  convergence_strategy: ${AO_CONVERGENCE_STRATEGY}
  stagnation_limit: ${AO_STAGNATION_LIMIT}

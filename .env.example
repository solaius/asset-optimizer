# Asset Optimizer Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================================================
# ACTIVE CONFIGURATION
# ============================================================================

# --- Default Provider Selection ---
# Text options: openai, claude, gemini, vllm, ollama
# Image options: openai_image, gemini, nano_banana
AO_DEFAULT_TEXT_PROVIDER=openai
AO_DEFAULT_IMAGE_PROVIDER=gemini
AO_DEFAULT_TEXT_MODEL=gpt-4o
AO_DEFAULT_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# --- AI Judge ---
# Optionally use a different provider/model for scoring (defaults to text provider)
# Useful when you want a cheaper model for improvement but a stronger one for judging
AO_JUDGE_PROVIDER=
AO_JUDGE_MODEL=

# --- API Keys ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
NANO_BANANA_API_KEY=your-nano-banana-key-here
NANO_BANANA_ENDPOINT=https://api.nanobanana.com/v1

# --- vLLM (uncomment to enable) ---
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3-70B
# VLLM_API_KEY=EMPTY

# --- Ollama (uncomment to enable) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3

# --- Optimization Defaults ---
AO_MAX_ITERATIONS=20
AO_CONVERGENCE_STRATEGY=greedy
AO_STAGNATION_LIMIT=5
AO_MIN_IMPROVEMENT=0.01

# ============================================================================
# PROVIDER PRESETS — uncomment one block to switch providers quickly
# ============================================================================

# --- PRESET: OpenAI (text + image) ---
# AO_DEFAULT_TEXT_PROVIDER=openai
# AO_DEFAULT_TEXT_MODEL=gpt-4o
# AO_DEFAULT_IMAGE_PROVIDER=openai_image
# AO_DEFAULT_IMAGE_MODEL=dall-e-3
#
# OpenAI text models:
#   gpt-4o           — best quality, multimodal (recommended)
#   gpt-4o-mini      — fast and cheap, good for iteration
#   gpt-4.1          — latest GPT-4.1, strong reasoning
#   gpt-4.1-mini     — smaller GPT-4.1, good balance
#   gpt-4.1-nano     — smallest GPT-4.1, fastest
#   o3               — reasoning model, best for complex tasks
#   o3-mini          — smaller reasoning model
#   o4-mini          — latest small reasoning model
#
# OpenAI image models:
#   dall-e-3         — high quality image generation
#   dall-e-2         — faster, lower cost
#   gpt-image-1      — newest OpenAI image model (2025)

# --- PRESET: Gemini (text + image) ---
# AO_DEFAULT_TEXT_PROVIDER=gemini
# AO_DEFAULT_TEXT_MODEL=gemini-2.5-pro-preview-06-05
# AO_DEFAULT_IMAGE_PROVIDER=gemini
# AO_DEFAULT_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
#
# Gemini text models:
#   gemini-2.5-pro-preview-06-05  — best quality, deep thinking (recommended)
#   gemini-2.5-flash-preview-05-20 — fast with thinking, good balance
#   gemini-2.0-flash              — fastest, cheapest
#   gemini-2.0-flash-lite         — ultra-lightweight
#
# Gemini image models:
#   gemini-2.0-flash-preview-image-generation — native image generation

# --- PRESET: Claude (text only, pair with Gemini or OpenAI for images) ---
# AO_DEFAULT_TEXT_PROVIDER=claude
# AO_DEFAULT_TEXT_MODEL=claude-sonnet-4-20250514
# AO_DEFAULT_IMAGE_PROVIDER=gemini
# AO_DEFAULT_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
#
# Claude text models:
#   claude-opus-4-20250918   — most capable, best for complex tasks
#   claude-sonnet-4-20250514 — strong balance of speed and quality (recommended)
#   claude-haiku-4-5-20251001 — fastest, cheapest, good for iteration
#
# Note: Claude does not have image generation models.
# Pair with Gemini or OpenAI for image tasks.

# Asset Optimizer Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# OpenAI — used for text completion, AI-judged scoring, and image generation
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini — used for text completion and AI-judged scoring
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude — used for text completion and AI-judged scoring
ANTHROPIC_API_KEY=your-anthropic-key-here

# Nano Banana — used for image generation
NANO_BANANA_API_KEY=your-nano-banana-key-here
